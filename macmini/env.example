# =============================================================================
# World Monitor — Mac-mini native deploy env template
# =============================================================================
# Copy to <repo-root>/.env (gitignored) and fill in real values.
# Every value below is either:
#   - a generated secret (CHANGE_ME — replace with `openssl rand -hex 32`)
#   - a non-secret default you can leave as-is
#   - an empty API key (sign up at the URL in the comment, paste your key)
#
# The macmini/run/*.sh wrappers source this file with `set -a` so every
# variable defined here is auto-exported into the spawned service.
# See SELF_HOSTING.md → Required Environment Variables for the canonical
# explanation of each secret.
# =============================================================================

# ── Generated secrets ────────────────────────────────────────────────────────
# Generate with:  openssl rand -hex 32
# Required: every service wrapper fails fast if these are still CHANGE_ME.
REDIS_PASSWORD=CHANGE_ME              # Redis AUTH (--requirepass on redis.sh)
REDIS_TOKEN=CHANGE_ME                 # Bearer token for redis-rest proxy + Upstash client
RELAY_SHARED_SECRET=CHANGE_ME         # AIS relay auth — relay refuses to start without it
LOCAL_API_TOKEN=CHANGE_ME             # Bearer token the sidecar requires on every request

# ── Ports (all bound to 127.0.0.1 by the run wrappers) ───────────────────────
WM_WEB_PORT=3040                      # macmini/web-server.mjs
LOCAL_API_PORT=46123                  # src-tauri/sidecar/local-api-server.mjs
WM_RELAY_PORT=3004                    # scripts/ais-relay.cjs
WM_REDIS_REST_PORT=8079               # docker/redis-rest-proxy.mjs
WM_REDIS_PORT=6390                    # /opt/homebrew/bin/redis-server (NOT 6379 — brew collisions)

# ── Wiring ───────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=http://127.0.0.1:8079
# UPSTASH_REDIS_REST_TOKEN is set by each run wrapper from $REDIS_TOKEN
# (Upstash contract is the same REST URL + bearer the local proxy speaks).

LOCAL_API_MODE=docker                 # 'docker' mode — local handlers, no cloud proxy
LOCAL_API_CLOUD_FALLBACK=false        # never silently fall through to api.worldmonitor.app

# ── Data-source API keys ─────────────────────────────────────────────────────
# Empty defaults are fine — the app degrades gracefully (markers + UI hints show
# "key missing"). Sign up at the URL next to each variable; the free tier is
# enough for personal/self-hosted use. See SELF_HOSTING.md → API Keys.
FRED_API_KEY=                         # https://fred.stlouisfed.org/docs/api/api_key.html
FINNHUB_API_KEY=                      # https://finnhub.io (used by both sidecar + relay)
GROQ_API_KEY=                         # https://console.groq.com (LLM assessments)
OPENROUTER_API_KEY=                   # https://openrouter.ai (LLM fallback)

# ── AI news classifier + AI Insights panel (seed-insights.mjs / relay) ───────
# This pipeline uses its OWN provider chain (ollama -> openrouter -> groq), NOT
# LLM_API_URL. Point OLLAMA_* at any OpenAI-compatible endpoint. It must be a
# NON-reasoning model — the classifier budgets 300 tokens/headline, and reasoning
# models burn that on <think> and return nothing. (MiniMax-Text-01 works; the
# MiniMax M-series and Poolside Laguna all reason and fail here.)
# macmini/run/insights.sh warms the local digest + runs the seeder every 30 min.
OLLAMA_API_URL=                       # e.g. https://api.minimax.io  (code appends /v1/chat/completions)
OLLAMA_API_KEY=                       # bearer for the above
OLLAMA_MODEL=                         # e.g. MiniMax-Text-01 (non-reasoning)
API_BASE_URL=http://127.0.0.1:3040    # seed-insights warms the digest from the LOCAL web-server, not the cloud
EIA_API_KEY=                          # https://www.eia.gov/opendata/
NASA_FIRMS_API_KEY=                   # https://firms.modaps.eosdis.nasa.gov
AISSTREAM_API_KEY=                    # https://aisstream.io (relay needs this too)
ACLED_EMAIL=                          # https://acleddata.com
ACLED_PASSWORD=                       # OAuth flow — preferred over ACLED_ACCESS_TOKEN
AVIATIONSTACK_API=                    # https://aviationstack.com
CLOUDFLARE_API_TOKEN=                 # https://dash.cloudflare.com (Radar — paid)

# Self-host operator key — unlocks the intelligence tier (Country Instability / Strategic
# Risk / theater posture). Generate: printf "wmop_%s" "$(openssl rand -hex 24)". The sidecar
# validates X-WorldMonitor-Key against this comma-separated list; web-server.mjs injects the
# first value on the private hop. Empty = those panels stay gated.
WORLDMONITOR_VALID_KEYS=
